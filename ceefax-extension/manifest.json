{
  "manifest_version": 3,
  "name": "Ceefax",
  "version": "0.1.0",
  "description": "Recreates the Ceefax teletext experience as a New Tab override.",
  "browser_specific_settings": {
    "gecko": {
      "id": "ceefax@example.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "scripts": ["js/vendor/readability.js", "js/data.js", "background.js"]
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.theguardian.com/*",
    "https://api.open-meteo.com/*",
    "https://old.reddit.com/*"
  ]
}
